{
  "name": "@mini-slock/cloudflare",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mini-slock/hub-core build && wrangler dev",
    "deploy": "pnpm --filter @mini-slock/hub-core build && wrangler deploy",
    "typecheck": "pnpm --filter @mini-slock/hub-core build && tsc --noEmit",
    "test": "pnpm --filter @mini-slock/hub-core build && vitest run"
  },
  "dependencies": {
    "@mini-slock/hub-core": "workspace:*",
    "@mini-slock/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.41",
    "@cloudflare/workers-types": "^4.20260423.0",
    "@vitest/runner": "2.1",
    "@vitest/snapshot": "2.1",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9",
    "wrangler": "^4.45.0"
  }
}
