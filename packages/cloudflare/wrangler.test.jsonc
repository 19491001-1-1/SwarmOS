{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "xoxiang-hub-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "XOXIANG_ENV": "test",
    "XOXIANG_VERSION": "0.6.0-test"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "HUB",
        "class_name": "XoxiangHub"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["XoxiangHub"]
    }
  ]
}
