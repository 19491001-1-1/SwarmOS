{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "crewden-hub-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "CREWDEN_ENV": "test",
    "CREWDEN_VERSION": "1.5.1-test"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "HUB",
        "class_name": "CrewdenHub"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CrewdenHub"]
    }
  ]
}
