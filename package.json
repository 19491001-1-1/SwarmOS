{
  "name": "crewden",
  "private": true,
  "version": "0.6.0",
  "scripts": {
    "start": "bash start.sh",
    "dev": "pnpm --parallel --filter @crewden/server --filter @crewden/web dev",
    "daemon": "pnpm --filter @crewden/daemon start",
    "deploy:web:pages": "bash scripts/deploy-cloudflare-pages.sh",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.11.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.0"
  }
}
